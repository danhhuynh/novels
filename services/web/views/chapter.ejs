<%- include('partials/header') %>

    <div class="chapter-reading-page">
        <!-- Compact header with breadcrumb -->
        <div class="chapter-header">
            <div class="breadcrumb">
                <a href="/">Home</a>
                <span class="breadcrumb-sep">›</span>
                <a href="/novels/<%= novel.id %>">
                    <%= novel.title %>
                </a>
                <span class="breadcrumb-sep">›</span>
                <span>Ch. <%= chapterNumber %></span>
            </div>
            <h1 class="chapter-title-main">
                <%= novel.title %>
            </h1>
            <h2 class="chapter-subtitle">Chapter <%= chapterNumber %>: <%= chapter.title %>
            </h2>
        </div>

        <!-- Compact top navigation -->
        <div class="chapter-navigation">
            <div class="chapter-nav-row">
                <% if (navigation.hasPrevious) { %>
                    <a href="/chapters/<%= novel.id %>/<%= navigation.previousChapter %>" class="btn-nav" id="prev-btn"
                        aria-label="Previous chapter">
                        <span class="nav-icon">‹</span>
                        <span class="nav-label">Prev</span>
                    </a>
                    <% } else { %>
                        <span class="btn-nav btn-nav-disabled" aria-hidden="true">
                            <span class="nav-icon">‹</span>
                            <span class="nav-label">Prev</span>
                        </span>
                        <% } %>

                            <div class="chapter-selector">
                                <select id="chapter-select" onchange="jumpToChapter(this.value)"
                                    aria-label="Jump to chapter">
                                    <% navigation.allChapters.forEach(ch=> { %>
                                        <option value="<%= ch.number %>" <%=ch.number===chapterNumber ? 'selected' : ''
                                            %>>
                                            Ch. <%= ch.number %>: <%= ch.title %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <% if (navigation.hasNext) { %>
                                <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>" class="btn-nav"
                                    id="next-btn" aria-label="Next chapter">
                                    <span class="nav-label">Next</span>
                                    <span class="nav-icon">›</span>
                                </a>
                                <% } else { %>
                                    <span class="btn-nav btn-nav-disabled" aria-hidden="true">
                                        <span class="nav-label">Next</span>
                                        <span class="nav-icon">›</span>
                                    </span>
                                    <% } %>
            </div>
        </div>

        <!-- Reading controls toolbar -->
        <div class="reading-toolbar">
            <div class="toolbar-group">
                <button class="toolbar-btn" onclick="changeFontSize(-1)" aria-label="Decrease font size">A−</button>
                <span class="toolbar-value" id="font-size-display">16px</span>
                <button class="toolbar-btn" onclick="changeFontSize(1)" aria-label="Increase font size">A+</button>
            </div>
            <div class="toolbar-divider"></div>
            <button class="toolbar-btn" onclick="toggleTheme()" id="theme-toggle" aria-label="Toggle theme">🌙</button>
            <div class="toolbar-divider"></div>
            <span class="toolbar-progress">
                <%= chapterNumber %> / <%= navigation.totalChapters %>
            </span>
        </div>

        <!-- Chapter content -->
        <div class="chapter-content-section">
            <article class="chapter-text unselectable" id="chapter-text">
                <%- chapterContent %>
            </article>
        </div>

        <!-- Bottom navigation -->
        <div class="chapter-bottom-actions">
            <a href="/novels/<%= novel.id %>" class="bottom-action-btn back-btn">
                <span class="action-icon">←</span>
                <span>Chapter List</span>
            </a>
            <% if (navigation.hasNext) { %>
                <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>"
                    class="bottom-action-btn continue-btn">
                    <span>Continue Reading</span>
                    <span class="action-icon">→</span>
                </a>
                <% } else { %>
                    <div class="bottom-action-btn end-btn">
                        <span>✨ End of Novel</span>
                    </div>
                    <% } %>
        </div>
    </div>

    <!-- Sticky mobile bottom nav -->
    <div class="chapter-sticky-nav">
        <% if (navigation.hasPrevious) { %>
            <a href="/chapters/<%= novel.id %>/<%= navigation.previousChapter %>" class="sticky-nav-btn"
                aria-label="Previous chapter">
                ‹ Prev
            </a>
            <% } else { %>
                <span class="sticky-nav-btn sticky-nav-disabled">‹ Prev</span>
                <% } %>
                    <a href="/novels/<%= novel.id %>" class="sticky-nav-btn sticky-nav-center"
                        aria-label="Chapter list">
                        ☰ Ch. <%= chapterNumber %>/<%= navigation.totalChapters %>
                    </a>
                    <% if (navigation.hasNext) { %>
                        <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>" class="sticky-nav-btn"
                            aria-label="Next chapter">
                            Next ›
                        </a>
                        <% } else { %>
                            <span class="sticky-nav-btn sticky-nav-disabled">Next ›</span>
                            <% } %>
    </div>

    <style>
        .unselectable {
            -webkit-user-select: none;
            /* Safari */
            -moz-user-select: none;
            /* Firefox */
            -ms-user-select: none;
            /* IE10+/Edge */
            user-select: none;
            /* Standard */
        }
    </style>

    <script nonce="<%= nonce %>">
        function jumpToChapter(chapterNumber) {
            if (chapterNumber && chapterNumber !== '<%= chapterNumber %>') {
                window.location.href = `/chapters/<%= novel.id %>/${chapterNumber}`;
            }
        }

        // Reading preferences
        let fontSize = 16;
        let isDarkTheme = false;

        function changeFontSize(delta) {
            fontSize = Math.max(12, Math.min(24, fontSize + delta));
            document.getElementById('chapter-text').style.fontSize = fontSize + 'px';
            document.getElementById('font-size-display').textContent = fontSize + 'px';
            localStorage.setItem('fontSize', fontSize);
        }

        function toggleTheme() {
            isDarkTheme = !isDarkTheme;
            document.body.classList.toggle('dark-theme', isDarkTheme);
            document.getElementById('theme-toggle').textContent = isDarkTheme ? '☀️' : '🌙';
            localStorage.setItem('isDarkTheme', isDarkTheme);
        }

        // Load saved preferences
        window.addEventListener('load', function () {
            const savedFontSize = localStorage.getItem('fontSize');
            const savedTheme = localStorage.getItem('isDarkTheme');

            if (savedFontSize) {
                fontSize = parseInt(savedFontSize);
                document.getElementById('chapter-text').style.fontSize = fontSize + 'px';
                document.getElementById('font-size-display').textContent = fontSize + 'px';
            }

            if (savedTheme === 'true') {
                isDarkTheme = true;
                document.body.classList.add('dark-theme');
                document.getElementById('theme-toggle').textContent = '☀️';
            }
        });

        // Keyboard navigation and Anti-theft protection
        document.addEventListener('keydown', function (event) {
            // Nav shortcuts
            if (!event.ctrlKey && !event.metaKey) {
                if (event.key === 'ArrowLeft' || event.key === 'h') {
                    const prevBtn = document.getElementById('prev-btn');
                    if (prevBtn) prevBtn.click();
                } else if (event.key === 'ArrowRight' || event.key === 'l') {
                    const nextBtn = document.getElementById('next-btn');
                    if (nextBtn) nextBtn.click();
                }
            }

            // --- Anti-theft ---
            // Prevent F12
            if (event.key === 'F12') {
                event.preventDefault();
                return false;
            }

            if (event.ctrlKey || event.metaKey) {
                const key = event.key.toLowerCase();
                // Prevent Ctrl+Shift+I, J, C (DevTools/Console/Inspect)
                if (event.shiftKey && (key === 'i' || key === 'j' || key === 'c')) {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+U (View Source)
                if (key === 'u') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+S (Save)
                if (key === 's') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+P (Print)
                if (key === 'p') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+C / Ctrl+X (Copy/Cut) on the whole document for extra safety
                if (key === 'c' || key === 'x') {
                    event.preventDefault();
                    return false;
                }
            }
        });

        // Hide/show sticky nav on scroll for immersive reading
        let lastScrollY = window.scrollY;
        const stickyNav = document.querySelector('.chapter-sticky-nav');
        window.addEventListener('scroll', function () {
            const currentScrollY = window.scrollY;
            if (currentScrollY > lastScrollY && currentScrollY > 200) {
                stickyNav.classList.add('sticky-nav-hidden');
            } else {
                stickyNav.classList.remove('sticky-nav-hidden');
            }
            lastScrollY = currentScrollY;
        }, { passive: true });

        // --- Additional anti-theft bindings ---
        const chapterText = document.getElementById('chapter-text');
        if (chapterText) {
            // Disable right click
            chapterText.addEventListener('contextmenu', e => e.preventDefault());

            // Disable copy/cut
            chapterText.addEventListener('copy', e => e.preventDefault());
            chapterText.addEventListener('cut', e => e.preventDefault());

            // Disable dragging elements (like images or text chunks)
            chapterText.addEventListener('dragstart', e => e.preventDefault());
        }

        // Global context menu disable for the whole body just in case
        document.addEventListener('contextmenu', e => {
            if (e.target.closest('#chapter-text') || e.target.nodeName === 'IMG') {
                e.preventDefault();
            }
        });
    </script>

    <%- include('partials/footer') %>
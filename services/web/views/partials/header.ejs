<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Vô Ngữ Quán — Đọc truyện, tiểu thuyết, linh dị, tiên hiệp, kiếm hiệp, truyện chữ online miễn phí. Thư viện truyện chọn lọc, cập nhật nhanh nhất.">
    <meta name="keywords"
        content="truyện chữ, đọc truyện, tiểu thuyết, linh dị, tiên hiệp, kiếm hiệp, truyện online, vô ngữ quán, novelreads">
    <meta name="author" content="Vô Ngữ Quán">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title + ' — Vô Ngữ Quán' : 'Vô Ngữ Quán' %>">
    <meta property="og:description"
        content="Vô Ngữ Quán — Đọc truyện, tiểu thuyết, linh dị, tiên hiệp, kiếm hiệp, truyện chữ online miễn phí. Thư viện truyện chọn lọc, cập nhật nhanh nhất.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://vonguquan.com/">
    <meta property="og:site_name" content="Vô Ngữ Quán">
    <meta property="og:locale" content="vi_VN">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title + ' — Vô Ngữ Quán' : 'Vô Ngữ Quán' %>">
    <meta name="twitter:description"
        content="Vô Ngữ Quán — Đọc truyện, tiểu thuyết, linh dị, tiên hiệp, kiếm hiệp, truyện chữ online miễn phí. Thư viện truyện chọn lọc, cập nhật nhanh nhất.">
    <link rel="icon" href="/assets/logo.png" type="image/png">
    <title>
        <%= typeof title !=='undefined' ? title + ' — Vô Ngữ Quán' : 'Vô Ngữ Quán' %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-K5YJC93ZVJ" nonce="<%= nonce %>"></script>
    <script nonce="<%= nonce %>">
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-K5YJC93ZVJ');
    </script>
    <script src="/js/auth-session.js" defer></script>
</head>

<body>
    <header class="header">
        <nav class="navbar">
            <div class="container nav-container">
                <a href="/" class="nav-logo">
                    <img src="/assets/logo.png" alt="Vô Ngữ Quán Logo" class="logo-icon"
                        style="width:32px;height:32px;">
                    <span class="logo-text">Vô Ngữ Quán</span>
                </a>
                <div class="nav-menu">
                    <a href="/" class="nav-link">Trang Chủ</a>
                    <a href="/#genres" class="nav-link">Thể Loại</a>
                    <% if (locals.user) { %>
                        <div class="user-menu"
                            style="display: flex; align-items: center; gap: 12px; margin-left: 10px;">
                            <span class="user-name" style="color: var(--primary-color); font-weight: 500;">
                                <%= locals.user.username %>
                            </span>
                            <button onclick="handleLogout()" class="btn btn-outline"
                                style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Đăng Xuất</button>
                        </div>
                        <% } else { %>
                            <div class="auth-buttons" style="display: flex; gap: 8px; margin-left: 10px;">
                                <a href="/login" class="btn btn-outline"
                                    style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Đăng Nhập</a>
                                <a href="/register" class="btn btn-primary"
                                    style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Đăng Ký</a>
                            </div>
                            <% } %>
                </div>

                <button class="navbar-toggle" aria-label="Mở menu" onclick="document.body.classList.toggle('nav-open')">
                    <span class="navbar-toggle-icon"></span>
                </button>

                <script nonce="<%= nonce %>">
                    async function handleLogout() {
                        try {
                            const res = await fetch('/api/auth/logout', { method: 'POST' });
                            if (res.ok) window.location.reload();
                        } catch (err) {
                            console.error('Logout failed', err);
                        }
                    }
                </script>
            </div>
        </nav>
    </header>

    <main class="main-content">
        <style>
            @media (max-width: 768px) {
                .nav-menu {
                    position: fixed;
                    top: 60px;
                    left: 0;
                    right: 0;
                    background: var(--bg-secondary);
                    flex-direction: column;
                    align-items: flex-start;
                    padding: 1rem 2rem;
                    gap: 1rem;
                    z-index: 1001;
                    display: none;
                }
                body.nav-open .nav-menu {
                    display: flex;
                }
                .navbar-toggle {
                    display: inline-flex;
                    background: none;
                    border: none;
                    cursor: pointer;
                    margin-left: auto;
                    align-items: center;
                    height: 40px;
                }
                .navbar-toggle-icon {
                    width: 28px;
                    height: 3px;
                    background: var(--accent);
                    display: block;
                    border-radius: 2px;
                    position: relative;
                }
                .navbar-toggle-icon::before,
                .navbar-toggle-icon::after {
                    content: '';
                    position: absolute;
                    left: 0;
                    width: 28px;
                    height: 3px;
                    background: var(--accent);
                    border-radius: 2px;
                    transition: 0.3s;
                }
                .navbar-toggle-icon::before {
                    top: -9px;
                }
                .navbar-toggle-icon::after {
                    top: 9px;
                }
            }
            @media (max-width: 480px) {
                .nav-menu {
                    padding: 1rem 1rem;
                }
            }
        </style>
    </main>
</body>

</html>
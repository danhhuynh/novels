<%- include('partials/header') %>

    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <img src="/assets/logo.png" alt="Vô Ngữ Quán Logo" style="width:48px;height:48px;margin-bottom:12px;">
                <h2 class="hero-title">Discover Your Next Great Read</h2>
                <p class="hero-subtitle">Explore our curated collection of novels</p>
            </div>

            <div class="search-section">
                <div class="search-container">
                    <input type="text" id="searchInput" class="search-input"
                        placeholder="Search by title, author, or genre...">
                    <button id="searchBtn" class="search-btn">🔍 Search</button>
                    <button id="showAllBtn" class="show-all-btn">Show All</button>
                </div>
            </div>
        </div>
    </section>

    <section class="novels-section">
        <div class="container">
            <div class="novels-grid" id="novelsGrid">
                <% if (novels && novels.length> 0) { %>
                    <% novels.forEach(novel=> { %>
                        <div class="novel-card">
                            <div class="novel-card-header">
                                <h2 class="novel-title">
                                    <a href="/novels/<%= novel.id %>">
                                        <%= novel.title %>
                                    </a>
                                </h2>
                                <p class="novel-author">by <%= novel.author %>
                                </p>
                            </div>
                            <div class="novel-genre">
                                <span class="genre-tag">
                                    <%= novel.genre %>
                                </span>
                            </div>
                            <p class="novel-description">
                                <%= novel.description || 'No description available.' %>
                            </p>
                            <div class="novel-meta">
                                <span>📊 <%= novel.status %></span>
                                <span>📖 <%= novel.totalChapters || 'Unknown' %> chapters</span>
                            </div>
                            <div class="novel-actions">
                                <% if (novel.chapters && novel.chapters.length> 0) { %>
                                    <a href="/chapters/<%= novel.id %>/1" class="btn-primary">Start Reading</a>
                                    <% } else { %>
                                        <a href="/novels/<%= novel.id %>" class="btn-primary">View Details</a>
                                        <% } %>
                                            <a href="/novels/<%= novel.id %>" class="btn-secondary">Details</a>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="empty-state">
                                    <div class="empty-icon">📭</div>
                                    <h3>No novels found</h3>
                                    <p>Check back later for new additions!</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>
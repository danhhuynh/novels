{
  "name": "novels-monorepo",
  "version": "1.0.0",
  "description": "Novel reading platform monorepo",
  "private": true,
  "scripts": {
    "install:web": "cd services/web && npm install",
    "install:auth": "cd services/auth && npm install",
    "install:all": "npm run install:web && npm run install:auth",
    "dev:web": "cd services/web && npm run dev",
    "dev:auth": "cd services/auth && npm run dev",
    "start:web": "cd services/web && npm start",
    "start:auth": "cd services/auth && npm start",
    "build": "cd services/web && npm run build",
    "seed": "node shared/database/seed.js",
    "pm2:start": "npm run build && pm2 start ecosystem.config.js --env production",
    "pm2:reload:web": "npm run build && pm2 reload novels-web",
    "pm2:reload:auth": "pm2 reload novels-auth",
    "pm2:reload:all": "npm run build && pm2 reload novels-web && pm2 reload novels-auth"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "aws-sdk": "^2.1693.0",
    "dotenv": "^16.6.1",
    "sqlite3": "^5.1.7"
  }
}

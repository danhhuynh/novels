<%- include('partials/header') %>

    <div class="x9856067b">
        <!-- Compact header with breadcrumb -->
        <div class="x73ae46c2">
            <div class="xe7703310">
                <a href="/">Home</a>
                <span class="x6779ec8f">›</span>
                <a href="/novels/<%= novel.id %>">
                    <%= novel.title %>
                </a>
                <span class="x6779ec8f">›</span>
                <span>Ch. <%= chapterNumber %></span>
            </div>
            <h1 class="xc6ba0beb">
                <%= novel.title %>
            </h1>
            <h2 class="xd92ced0e">Chapter <%= chapterNumber %>: <%= chapter.title %>
            </h2>
        </div>

        <!-- Compact top navigation -->
        <div class="x93ed57ee">
            <div class="x684acac0">
                <% if (navigation.hasPrevious) { %>
                    <a href="/chapters/<%= novel.id %>/<%= navigation.previousChapter %>" class="xeb2a6a82" id="prev-btn"
                        aria-label="Previous chapter">
                        <span class="nav-icon">‹</span>
                        <span class="xcb4fa3c8">Prev</span>
                    </a>
                    <% } else { %>
                        <span class="xeb2a6a82 xda709d5f" aria-hidden="true">
                            <span class="nav-icon">‹</span>
                            <span class="xcb4fa3c8">Prev</span>
                        </span>
                        <% } %>

                            <div class="xf4b95279">
                                <select id="chapter-select" onchange="jumpToChapter(this.value)"
                                    aria-label="Jump to chapter">
                                    <% navigation.allChapters.forEach(ch=> { %>
                                        <option value="<%= ch.number %>" <%=ch.number===chapterNumber ? 'selected' : ''
                                            %>>
                                            Ch. <%= ch.number %>: <%= ch.title %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <% if (navigation.hasNext) { %>
                                <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>" class="xeb2a6a82"
                                    id="next-btn" aria-label="Next chapter">
                                    <span class="xcb4fa3c8">Next</span>
                                    <span class="nav-icon">›</span>
                                </a>
                                <% } else { %>
                                    <span class="xeb2a6a82 xda709d5f" aria-hidden="true">
                                        <span class="xcb4fa3c8">Next</span>
                                        <span class="nav-icon">›</span>
                                    </span>
                                    <% } %>
            </div>
        </div>

        <!-- Reading controls toolbar -->
        <div class="x552d531e">
            <div class="x59de489c">
                <button class="x6ac7a332" onclick="changeFontSize(-1)" aria-label="Decrease font size">A−</button>
                <span class="xf94ebbb4" id="font-size-display">16px</span>
                <button class="x6ac7a332" onclick="changeFontSize(1)" aria-label="Increase font size">A+</button>
            </div>
            <div class="xa192526c"></div>
            <button class="x6ac7a332" onclick="toggleTheme()" id="theme-toggle" aria-label="Toggle theme">🌙</button>
            <div class="xa192526c"></div>
            <span class="x87401a81">
                <%= chapterNumber %> / <%= navigation.totalChapters %>
            </span>
        </div>

        <!-- Chapter content -->
        <div class="x81095bfb">
            <article class="x106f658e unselectable" id="chapter-text">
                <%- chapterContent %>
            </article>
        </div>

        <!-- Bottom navigation -->
        <div class="x70d9f801">
            <a href="/novels/<%= novel.id %>" class="x66c61b11 x7d7acfca">
                <span class="action-icon">←</span>
                <span>Chapter List</span>
            </a>
            <% if (navigation.hasNext) { %>
                <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>"
                    class="x66c61b11 x71fd44d7">
                    <span>Continue Reading</span>
                    <span class="action-icon">→</span>
                </a>
                <% } else { %>
                    <div class="x66c61b11 xf7717494">
                        <span>✨ End of Novel</span>
                    </div>
                    <% } %>
        </div>
    </div>

    <!-- Sticky mobile bottom nav -->
    <div class="x76e010ad">
        <% if (navigation.hasPrevious) { %>
            <a href="/chapters/<%= novel.id %>/<%= navigation.previousChapter %>" class="x34f0492b"
                aria-label="Previous chapter">
                ‹ Prev
            </a>
            <% } else { %>
                <span class="x34f0492b x48109f86">‹ Prev</span>
                <% } %>
                    <a href="/novels/<%= novel.id %>" class="x34f0492b x47280ab0"
                        aria-label="Chapter list">
                        ☰ Ch. <%= chapterNumber %>/<%= navigation.totalChapters %>
                    </a>
                    <% if (navigation.hasNext) { %>
                        <a href="/chapters/<%= novel.id %>/<%= navigation.nextChapter %>" class="x34f0492b"
                            aria-label="Next chapter">
                            Next ›
                        </a>
                        <% } else { %>
                            <span class="x34f0492b x48109f86">Next ›</span>
                            <% } %>
    </div>

    <style>
        .unselectable {
            -webkit-user-select: none;
            /* Safari */
            -moz-user-select: none;
            /* Firefox */
            -ms-user-select: none;
            /* IE10+/Edge */
            user-select: none;
            /* Standard */
        }
    </style>

    <script nonce="<%= nonce %>">
        function jumpToChapter(chapterNumber) {
            if (chapterNumber && chapterNumber !== '<%= chapterNumber %>') {
                window.location.href = `/chapters/<%= novel.id %>/${chapterNumber}`;
            }
        }

        // Reading preferences
        let fontSize = 16;
        let isDarkTheme = false;

        function changeFontSize(delta) {
            fontSize = Math.max(12, Math.min(24, fontSize + delta));
            document.getElementById('chapter-text').style.fontSize = fontSize + 'px';
            document.getElementById('font-size-display').textContent = fontSize + 'px';
            localStorage.setItem('fontSize', fontSize);
        }

        function toggleTheme() {
            isDarkTheme = !isDarkTheme;
            document.body.classList.toggle('dark-theme', isDarkTheme);
            document.getElementById('theme-toggle').textContent = isDarkTheme ? '☀️' : '🌙';
            localStorage.setItem('isDarkTheme', isDarkTheme);
        }

        // Load saved preferences
        window.addEventListener('load', function () {
            const savedFontSize = localStorage.getItem('fontSize');
            const savedTheme = localStorage.getItem('isDarkTheme');

            if (savedFontSize) {
                fontSize = parseInt(savedFontSize);
                document.getElementById('chapter-text').style.fontSize = fontSize + 'px';
                document.getElementById('font-size-display').textContent = fontSize + 'px';
            }

            if (savedTheme === 'true') {
                isDarkTheme = true;
                document.body.classList.add('dark-theme');
                document.getElementById('theme-toggle').textContent = '☀️';
            }
        });

        // Keyboard navigation and Anti-theft protection
        document.addEventListener('keydown', function (event) {
            // Nav shortcuts
            if (!event.ctrlKey && !event.metaKey) {
                if (event.key === 'ArrowLeft' || event.key === 'h') {
                    const prevBtn = document.getElementById('prev-btn');
                    if (prevBtn) prevBtn.click();
                } else if (event.key === 'ArrowRight' || event.key === 'l') {
                    const nextBtn = document.getElementById('next-btn');
                    if (nextBtn) nextBtn.click();
                }
            }

            // --- Anti-theft ---
            // Prevent F12
            if (event.key === 'F12') {
                event.preventDefault();
                return false;
            }

            if (event.ctrlKey || event.metaKey) {
                const key = event.key.toLowerCase();
                // Prevent Ctrl+Shift+I, J, C (DevTools/Console/Inspect)
                if (event.shiftKey && (key === 'i' || key === 'j' || key === 'c')) {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+U (View Source)
                if (key === 'u') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+S (Save)
                if (key === 's') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+P (Print)
                if (key === 'p') {
                    event.preventDefault();
                    return false;
                }
                // Prevent Ctrl+C / Ctrl+X (Copy/Cut) on the whole document for extra safety
                if (key === 'c' || key === 'x') {
                    event.preventDefault();
                    return false;
                }
            }
        });

        // Hide/show sticky nav on scroll for immersive reading
        let lastScrollY = window.scrollY;
        const stickyNav = document.querySelector('.x76e010ad');
        window.addEventListener('scroll', function () {
            const currentScrollY = window.scrollY;
            if (currentScrollY > lastScrollY && currentScrollY > 200) {
                stickyNav.classList.add('x48eec726');
            } else {
                stickyNav.classList.remove('x48eec726');
            }
            lastScrollY = currentScrollY;
        }, { passive: true });

        // --- Additional anti-theft bindings ---
        const chapterText = document.getElementById('chapter-text');
        if (chapterText) {
            // Disable right click
            chapterText.addEventListener('contextmenu', e => e.preventDefault());

            // Disable copy/cut
            chapterText.addEventListener('copy', e => e.preventDefault());
            chapterText.addEventListener('cut', e => e.preventDefault());

            // Disable dragging elements (like images or text chunks)
            chapterText.addEventListener('dragstart', e => e.preventDefault());
        }

        // Global context menu disable for the whole body just in case
        document.addEventListener('contextmenu', e => {
            if (e.target.closest('#chapter-text') || e.target.nodeName === 'IMG') {
                e.preventDefault();
            }
        });
    </script>

    <%- include('partials/footer') %>
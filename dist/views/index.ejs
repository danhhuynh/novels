<%- include('partials/header') %>

    <section class="xb87fb986">
        <div class="xcc1a5edc">
            <div class="hero-content">
                <img src="/assets/logo.png" alt="Vô Ngữ Quán Logo" style="width:48px;height:48px;margin-bottom:12px;">
                <h2 class="x0f6a9507">Discover Your Next Great Read</h2>
                <p class="x82870522">Explore our curated collection of novels</p>
            </div>

            <div class="x127b55b5">
                <div class="x5029dd9e">
                    <input type="text" id="searchInput" class="xfa769459"
                        placeholder="Search by title, author, or genre...">
                    <button id="searchBtn" class="xd0c0014d">🔍 Search</button>
                    <button id="showAllBtn" class="x0fe30e53">Show All</button>
                </div>
            </div>
        </div>
    </section>

    <section class="x5f50dacc">
        <div class="xcc1a5edc">
            <div class="x3595bf1f" id="novelsGrid">
                <% if (novels && novels.length> 0) { %>
                    <% novels.forEach(novel=> { %>
                        <div class="x52e80831">
                            <div class="xdcac961f">
                                <h2 class="x3f65f0e9">
                                    <a href="/novels/<%= novel.id %>">
                                        <%= novel.title %>
                                    </a>
                                </h2>
                                <p class="x352f8e5a">by <%= novel.author %>
                                </p>
                            </div>
                            <div class="xe1339419">
                                <span class="x4baffbf1">
                                    <%= novel.genre %>
                                </span>
                            </div>
                            <p class="xa75a6c3c">
                                <%= novel.description || 'No description available.' %>
                            </p>
                            <div class="xe31df97a">
                                <span>📊 <%= novel.status %></span>
                                <span>📖 <%= novel.totalChapters || 'Unknown' %> chapters</span>
                            </div>
                            <div class="xfd804b3f">
                                <% if (novel.chapters && novel.chapters.length> 0) { %>
                                    <a href="/chapters/<%= novel.id %>/1" class="x504854fd">Start Reading</a>
                                    <% } else { %>
                                        <a href="/novels/<%= novel.id %>" class="x504854fd">View Details</a>
                                        <% } %>
                                            <a href="/novels/<%= novel.id %>" class="x7d440cc3">Details</a>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div class="xfd34e0a6">
                                    <div class="xd9054b40">📭</div>
                                    <h3>No novels found</h3>
                                    <p>Check back later for new additions!</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>